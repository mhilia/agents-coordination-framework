# AISStream.io — https://aisstream.io (compte gratuit suffisant pour la POC)
AISSTREAM_API_KEY=your_aisstream_api_key

# Confluent Cloud — Kafka cluster credentials
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.region.gcp.confluent.cloud:9092
KAFKA_API_KEY=your_confluent_api_key
KAFKA_API_SECRET=your_confluent_api_secret
